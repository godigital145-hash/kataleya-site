---
import CatalogueDetail from "../../components/pages/catalogueDetail";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
    return [{ params: { id: "_" } }];
}

const { id } = Astro.params;
---

<Layout>
